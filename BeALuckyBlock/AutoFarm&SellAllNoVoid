-- TRẠNG THÁI MẶC ĐỊNH LÀ CHẠY
local _autoFarmActive = true
local _autoSellActive = true
local player = game.Players.LocalPlayer

-- Tìm Plot (Nếu không tìm thấy sau 5 giây sẽ báo lỗi để mày biết)
local targetPath = workspace:WaitForChild("Plots"):WaitForChild("3"):WaitForChild("3"):WaitForChild("PlotSurface"):WaitForChild("Part")

-- Khai báo Service và Remotes
local Rep = game:GetService("ReplicatedStorage")
local KnitPath = Rep:WaitForChild("Packages"):WaitForChild("_Index"):WaitForChild("sleitnick_knit@1.7.0"):WaitForChild("knit"):WaitForChild("Services")

local StartRunRF = KnitPath:WaitForChild("RunningService"):WaitForChild("RF"):WaitForChild("StartRun")
local ReloadCharRF = KnitPath:WaitForChild("PlayerService"):WaitForChild("RF"):WaitForChild("ReloadCharacter")
local OpenLuckyBlockRF = KnitPath:WaitForChild("RunningService"):WaitForChild("RF"):WaitForChild("OpenLuckyBlock")
local SellRemote = KnitPath:WaitForChild("InventoryService"):WaitForChild("RF"):WaitForChild("SellBrainrot")

---------------- LOGIC AUTO SELL ----------------
local function runAutoSell()
    while _autoSellActive do
        pcall(function()
            local items = {}
            for _, v in ipairs(player.Backpack:GetChildren()) do if v:IsA("Tool") then table.insert(items, v) end end
            if player.Character then
                for _, v in ipairs(player.Character:GetChildren()) do if v:IsA("Tool") then table.insert(items, v) end end
            end

            for _, tool in ipairs(items) do
                local entityId = tool:GetAttribute("EntityId")
                if entityId then
                    local mutation = tostring(tool:GetAttribute("Mutation") or "NORMAL"):upper()
                    if mutation ~= "VOID" then
                        SellRemote:InvokeServer(entityId)
                        task.wait(0.05)
                    end
                end
            end
        end)
        task.wait(2)
    end
end

---------------- LOGIC AUTO FARM ----------------
local function startFarmLoop()
    -- Kích hoạt chạy và hồi sinh nhân vật 1 lần duy nhất khi bắt đầu
    pcall(function() 
        StartRunRF:InvokeServer() 
        ReloadCharRF:InvokeServer()
    end)

    while _autoFarmActive do
        task.wait()
        -- Mở hòm
        task.spawn(function() pcall(function() OpenLuckyBlockRF:InvokeServer("base15") end) end)
        -- Teleport tới vị trí farm
        pcall(function()
            if player.Character and targetPath then
                player.Character:PivotTo(targetPath.CFrame + Vector3.new(0, 10, 0))
            end
        end)
    end
end

local function runAutoSellPetName()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local player = Players.LocalPlayer

    -- Lấy chính xác đường dẫn Remote từ source [cite: 38, 39, 40]
    local SellBrainrot = ReplicatedStorage
        :WaitForChild("Packages")
        :WaitForChild("_Index")
        :WaitForChild("sleitnick_knit@1.7.0")
        :WaitForChild("knit")
        :WaitForChild("Services")
        :WaitForChild("InventoryService")
        :WaitForChild("RF")
        :WaitForChild("SellBrainrot")

    local function GetAllTools()
        local tools = {}
        -- Quét túi đồ 
        for _, item in ipairs(player.Backpack:GetChildren()) do
            if item:IsA("Tool") then table.insert(tools, item) end
        end
        -- Quét trên tay nhân vật 
        if player.Character then
            for _, item in ipairs(player.Character:GetChildren()) do
                if item:IsA("Tool") then table.insert(tools, item) end
            end
        end
        return tools
    end

    local items = GetAllTools()
    for _, tool in ipairs(items) do
        -- Lấy mã ID và Tên pet từ Attribute [cite: 97, 98]
        local entityId = tool:GetAttribute("EntityId")
        local brainrotType = tool:GetAttribute("BrainrotType")

        -- KIỂM TRA ĐIỀU KIỆN: 
        -- 1. Phải có ID thực thể
        -- 2. Tên pet KHÔNG ĐƯỢC là "bisonte_giuppitere_giuppitercito"
        if entityId and brainrotType ~= "bisonte_giuppitere_giuppitercito" then
            pcall(function()
                -- Sử dụng InvokeServer theo đúng cấu trúc của script [cite: 40]
                SellBrainrot:InvokeServer(entityId)
            end)
            task.wait(0.1) -- Nghỉ một chút để tránh bị giới hạn tốc độ (Rate limit)
        end
    end
end
