---------------- LOGIC AUTO SELL ----------------
local function runAutoSellCombined()
    local Players = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local player = Players.LocalPlayer

    -- Đường dẫn Remote từ source bạn cung cấp
    local SellBrainrot = ReplicatedStorage
        :WaitForChild("Packages")
        :WaitForChild("_Index")
        :WaitForChild("sleitnick_knit@1.7.0")
        :WaitForChild("knit")
        :WaitForChild("Services")
        :WaitForChild("InventoryService")
        :WaitForChild("RF")
        :WaitForChild("SellBrainrot")

    -- Vòng lặp chạy liên tục (Dựa trên đoạn code 1)
    while _autoSellActive do
        pcall(function()
            local items = {}
            -- Thu thập đồ trong Backpack
            for _, v in ipairs(player.Backpack:GetChildren()) do 
                if v:IsA("Tool") then table.insert(items, v) end 
            end
            -- Thu thập đồ đang cầm trên tay
            if player.Character then
                for _, v in ipairs(player.Character:GetChildren()) do 
                    if v:IsA("Tool") then table.insert(items, v) end 
                end
            end

            -- Duyệt danh sách để bán
            for _, tool in ipairs(items) do
                local entityId = tool:GetAttribute("EntityId")
                local brainrotType = tool:GetAttribute("BrainrotType")
                local mutation = tostring(tool:GetAttribute("Mutation") or "NORMAL"):upper()

                if entityId then
                    -- ĐIỀU KIỆN ĐỂ KHÔNG BÁN (Giữ lại):
                    -- Tên phải là "bisonte_giuppitere_giuppitercito" VÀ hệ phải là "VOID"
                    local isSafePet = (brainrotType == "bisonte_giuppitere_giuppitercito" and mutation == "VOID")

                    if not isSafePet then
                        -- Nếu KHÔNG PHẢI con pet an toàn đó thì BÁN
                        SellBrainrot:InvokeServer(entityId)
                        task.wait(0.05) -- Chờ ngắn để tránh lag
                    end
                end
            end
        end)
        
        task.wait(2) -- Quét lại túi đồ sau mỗi 2 giây
    end
end

-- Kích hoạt chạy ngầm
task.spawn(runAutoSellCombined)
