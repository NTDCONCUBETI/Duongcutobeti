---------------- LOGIC BÁN (SELL) ----------------
local function runAutoSell()
    while _autoSellActive do
        local tools = {}
        for _, v in ipairs(player.Backpack:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end
        if player.Character then
            for _, v in ipairs(player.Character:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end
        end

        for _, tool in ipairs(tools) do
            if not _autoSellActive then break end
            local entityId = tool:GetAttribute("EntityId")
            if entityId then
                local mutation = tool:GetAttribute("Mutation")
                if tostring(mutation):upper() ~= "VOID" then
                    pcall(function() SellRemote:InvokeServer(entityId) end)
                    task.wait(0.05)
                end
            end
        end
        task.wait(1) -- Quét lại mỗi 1 giây
    end
end

---------------- LOGIC FARM ----------------
local function startFarmLoop()
    while _autoFarmActive do
        task.wait()
        task.spawn(function() pcall(function() OpenLuckyBlockRF:InvokeServer("base14") end) end)
        pcall(function()
            local char = player.Character
            if char and targetPath then char:PivotTo(targetPath.CFrame + Vector3.new(0, 10, 0)) end
        end)
    end
end

