local function fireConnections(signal)
	local ok, conns = pcall(function()
		return getconnections(signal)
	end)
	if not ok or not conns then return false end

	for _, c in ipairs(conns) do
		if c.Enabled then
			pcall(function()
				if typeof(c.Function) == "function" then
					c.Function()
				elseif typeof(c.Fire) == "function" then
					c:Fire()
				end
			end)
		end
	end
	return true
end
local function check_luckyblock()
	for _,v in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
		if v:IsA("Tool") and v:GetAttribute("LuckyBlockTool") and table.find(CONFIG.LuckyBlock,v:GetAttribute("LuckyBlockType")) then
