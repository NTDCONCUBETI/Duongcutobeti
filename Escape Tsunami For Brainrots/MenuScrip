-- Hiệu ứng nhấp nháy nhẹ
local TweenService = game:GetService("TweenService")
task.spawn(function()
    while starBtn.Parent do
        local tween1 = TweenService:Create(starBtn, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {TextColor3 = Color3.fromRGB(255, 255, 150)})
        tween1:Play()
        tween1.Completed:Wait()
        local tween2 = TweenService:Create(starBtn, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {TextColor3 = Color3.fromRGB(255, 215, 0)})
        tween2:Play()
        tween2.Completed:Wait()
    end
end)

-- Logic minimize (mặc định minimize)
local minimized = true
frame.Visible = false
starBtn.Visible = true

minimizeBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        frame.Visible = false
        starBtn.Visible = true
    else
        frame.Visible = true
        starBtn.Visible = false
    end
end)

-- Logic click ngôi sao để mở lại menu
