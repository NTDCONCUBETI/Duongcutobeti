-- Nội dung menu (toggle)
local function createToggle(name, posY, defaultOn)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 280, 0, 30)
    button.Position = UDim2.new(0, 10, 0, posY)
    button.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.SourceSans
    button.TextSize = 18
    button.Parent = frame

    local state = false

    local function setState(on)
        state = on
        if state then
            button.Text = name .. ": ON"
            button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
            if name == "Update Pet" then
                loadstring(game:HttpGet("https://raw.githubusercontent.com/duongcuteleu/main/refs/heads/main/UpLverPetFarmCoinLV230"))()
            elseif name == "Spamcoin" then
                loadstring(game:HttpGet("https://raw.githubusercontent.com/duongcuteleu/main/refs/heads/main/SpamCliamCoin"))()
            end
        else
            button.Text = name .. ": OFF"
            button.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
        end
        print(name .. " -> " .. tostring(state))
    end

    button.MouseButton1Click:Connect(function()
        setState(not state)
    end)

    if defaultOn then
        setState(true)
    else
        setState(false)
    end
end

createToggle("Update Pet", 40, false)
createToggle("Spamcoin", 80, true) -- mặc định ON

