task.wait(15) -- chờ game load 15 giây
loadstring(game:HttpGet("https://raw.githubusercontent.com/duongcuteleu/main/refs/heads/main/ClosePeopeoAndChat"))()
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Lưu vị trí hiện tại
local savedPosition = rootPart.Position
print("📌 Vị trí đã lưu:", savedPosition)

-- Hàm bay ngay lập tức về vị trí đã lưu
local function flyToSavedPosition()
	if not savedPosition then
		warn("⚠️ Chưa có vị trí nào được lưu!")
		return
	end
	-- Teleport trực tiếp bằng CFrame
	character.HumanoidRootPart.CFrame = CFrame.new(savedPosition + Vector3.new(0,5,0))
	print("🛫 Teleport về vị trí đã lưu:", savedPosition)
end

local remote = game:GetService("ReplicatedStorage")
	:WaitForChild("Shared")
	:WaitForChild("Remotes")
	:WaitForChild("Networking")
	:WaitForChild("RF/PlotAction")

local bases = workspace:WaitForChild("Bases")
local My_plot = nil

--########################################## Lấy địa chỉ nhà (chạy 1 lần)
for _, plot in ipairs(bases:GetChildren()) do
	local title = plot:FindFirstChild("Title")
	if title then
		local titleGui = title:FindFirstChild("TitleGui")
		if titleGui then
			local frame = titleGui:FindFirstChild("Frame")
			if frame then
				local playerNameLabel = frame:FindFirstChild("PlayerName")
				if playerNameLabel and playerNameLabel:IsA("TextLabel") then
					if playerNameLabel.Text == player.DisplayName then
						My_plot = plot
						break
					end
				end
			end
		end
	end
end

if not My_plot then
	warn("❌ Không tìm thấy plot của bạn!")
	return
end

